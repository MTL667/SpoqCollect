generator client {
  provider = "prisma-client"
  output   = "../server/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Inspector {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String             @map("password_hash")
  name         String
  role         String             @default("inspector")
  createdAt    DateTime           @default(now()) @map("created_at")
  sessions     InventorySession[]
  scanRecords  ScanRecord[]

  @@map("inspectors")
}

model BuildingType {
  id          String                    @id @default(cuid())
  nameNl      String                    @unique @map("name_nl")
  nameFr      String                    @map("name_fr")
  active      Boolean                   @default(true)
  sessions    InventorySession[]
  objectTypes ObjectTypeBuildingType[]

  @@map("building_types")
}

model ObjectType {
  id                    String                    @id @default(cuid())
  nameNl                String                    @map("name_nl")
  nameFr                String                    @map("name_fr")
  heliOmCategory        String                    @map("heli_om_category")
  active                Boolean                   @default(true)
  isCustom              Boolean                   @default(false) @map("is_custom")
  clientName            String?                   @map("client_name")
  exportParty           String                    @default("aceg") @map("export_party")
  parentObjectTypeId    String?                   @map("parent_object_type_id")
  parentObjectType      ObjectType?               @relation("ObjectTypeHierarchy", fields: [parentObjectTypeId], references: [id], onDelete: SetNull)
  childObjectTypes      ObjectType[]              @relation("ObjectTypeHierarchy")
  buildingTypes         ObjectTypeBuildingType[]
  scanRecords           ScanRecord[]
  serviceCodeMappings   ServiceCodeMapping[]
  profileMappingRules   ProfileMappingRule[]
  profileSubassetParent ProfileSubassetConfig[]   @relation("SubassetParent")
  profileSubassetChild  ProfileSubassetConfig[]   @relation("SubassetChild")
  profileSubcontractorLinks ProfileSubcontractorObjectType[]
  draftAssetsAsSuggestion DraftAsset[]            @relation("DraftAssetSuggestedType")

  @@unique([nameNl, clientName])
  @@map("object_types")
}

model ObjectTypeBuildingType {
  objectTypeId   String       @map("object_type_id")
  buildingTypeId String       @map("building_type_id")
  objectType     ObjectType   @relation(fields: [objectTypeId], references: [id])
  buildingType   BuildingType @relation(fields: [buildingTypeId], references: [id])

  @@id([objectTypeId, buildingTypeId])
  @@map("object_type_building_types")
}

model InventorySession {
  id                 String            @id @default(cuid())
  inspectorId        String            @map("inspector_id")
  clientName         String            @map("client_name")
  street             String
  number             String
  bus                String?
  postalCode         String            @map("postal_code")
  city               String
  buildingTypeId     String            @map("building_type_id")
  mappingProfileId   String?           @map("mapping_profile_id")
  status             String            @default("active")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  completedAt        DateTime?         @map("completed_at")
  sessionPromptData  Json?             @map("session_prompt_data")
  mappingVersion     Int               @default(1) @map("mapping_version")
  inspector          Inspector         @relation(fields: [inspectorId], references: [id])
  buildingType       BuildingType      @relation(fields: [buildingTypeId], references: [id])
  mappingProfile     MappingProfile?   @relation(fields: [mappingProfileId], references: [id])
  locations          Location[]
  scanRecords        ScanRecord[]
  priorReportFiles   PriorReportFile[]
  draftAssets        DraftAsset[]

  @@map("inventory_sessions")
}

model Location {
  id        String           @id @default(cuid())
  sessionId String           @map("session_id")
  name      String
  sortOrder Int              @default(0) @map("sort_order")
  createdAt DateTime         @default(now()) @map("created_at")
  session   InventorySession @relation(fields: [sessionId], references: [id])
  floors    Floor[]

  @@map("locations")
}

model Floor {
  id          String       @id @default(cuid())
  locationId  String       @map("location_id")
  name        String
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  location    Location     @relation(fields: [locationId], references: [id])
  scanRecords ScanRecord[]

  @@map("floors")
}

model ScanRecord {
  id                       String            @id @default(cuid())
  sessionId                String            @map("session_id")
  floorId                  String            @map("floor_id")
  inspectorId              String            @map("inspector_id")
  photoPath                String?           @map("photo_path")
  labelPhotoPath           String?           @map("label_photo_path")
  aiProposedTypeId         String?           @map("ai_proposed_type_id")
  aiConfidence             Float?            @map("ai_confidence")
  aiRawResponse            String?           @map("ai_raw_response")
  confirmedTypeId          String?           @map("confirmed_type_id")
  quantity                 Int               @default(1)
  status                   String            @default("pending")
  createdAt                DateTime          @default(now()) @map("created_at")
  confirmedAt              DateTime?         @map("confirmed_at")
  parentScanId             String?           @map("parent_scan_id")
  onScanPromptAnswers      Json?             @map("on_scan_prompt_answers")
  lastInspectionDate       DateTime?         @map("last_inspection_date")
  certifiedUntilDate       DateTime?         @map("certified_until_date")
  lbLmbPercentage          String?           @map("lb_lmb_percentage")
  lbLmbTestDate            DateTime?         @map("lb_lmb_test_date")
  inspectionComment        String?           @map("inspection_comment")
  externalInspectionNumber String?           @map("external_inspection_number")
  labelAiRawResponse       String?           @map("label_ai_raw_response")
  session              InventorySession  @relation(fields: [sessionId], references: [id])
  floor                Floor             @relation(fields: [floorId], references: [id])
  inspector            Inspector         @relation(fields: [inspectorId], references: [id])
  confirmedType        ObjectType?       @relation(fields: [confirmedTypeId], references: [id])
  parentScan           ScanRecord?       @relation("ScanHierarchy", fields: [parentScanId], references: [id], onDelete: SetNull)
  childScans           ScanRecord[]      @relation("ScanHierarchy")
  scanJob              ScanJob?
  matchedDraftAsset    DraftAsset?   @relation("DraftMatchedScan")

  @@index([parentScanId])
  @@map("scan_records")
}

/** Geüpload eerdere keuringsverslag: één PDF-bestand of map met fotobatch (imgbatch-*). */
model PriorReportFile {
  id                String       @id @default(cuid())
  sessionId         String       @map("session_id")
  originalName      String       @map("original_name")
  storedPath        String       @map("stored_path")
  mimeType          String       @default("application/pdf") @map("mime_type")
  extractionStatus  String       @default("pending") @map("extraction_status")
  extractionError   String?      @map("extraction_error")
  createdAt         DateTime     @default(now()) @map("created_at")
  session           InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  draftAssets       DraftAsset[]

  @@map("prior_report_files")
}

/**
 * Concept-asset uit vorig verslag (te activeren bij scan op locatie).
 * status: draft | matched | skipped
 */
model DraftAsset {
  id                    String            @id @default(cuid())
  sessionId             String            @map("session_id")
  priorReportFileId     String?           @map("prior_report_file_id")
  title                 String
  lastInspectionDate    DateTime?         @map("last_inspection_date")
  locationHint          String?           @map("location_hint")
  suggestedObjectTypeId String?           @map("suggested_object_type_id")
  rawExtraction         Json?             @map("raw_extraction")
  status                String            @default("draft")
  matchedScanId         String?           @unique @map("matched_scan_id")
  session               InventorySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  priorReportFile       PriorReportFile?  @relation(fields: [priorReportFileId], references: [id], onDelete: SetNull)
  suggestedObjectType   ObjectType?       @relation("DraftAssetSuggestedType", fields: [suggestedObjectTypeId], references: [id], onDelete: SetNull)
  matchedScan           ScanRecord?       @relation("DraftMatchedScan", fields: [matchedScanId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([status])
  @@map("draft_assets")
}

model ServiceCodeMapping {
  id                    String     @id @default(cuid())
  objectTypeId          String     @map("object_type_id")
  regime                String?
  region                String?
  minQuantity           Int?       @map("min_quantity")
  maxQuantity           Int?       @map("max_quantity")
  odooProductCode       String     @map("odoo_product_code")
  startPriceProductCode String?    @map("start_price_product_code")
  labelNl               String?    @map("label_nl")
  priority              Int        @default(0)
  active                Boolean    @default(true)
  version               Int        @default(1)
  objectType            ObjectType @relation(fields: [objectTypeId], references: [id], onDelete: Cascade)

  @@map("service_code_mappings")
}

model OdooProduct {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  category String?
  unit     String  @default("Stuks")
  active   Boolean @default(true)

  @@map("odoo_products")
}

model MappingProfile {
  id               String                  @id @default(cuid())
  name             String                  @unique
  country          String                  @default("BE")
  hasRegionLogic   Boolean                 @default(false) @map("has_region_logic")
  odooExportEnabled Boolean                @default(true)  @map("odoo_export_enabled")
  active           Boolean                 @default(true)
  createdAt        DateTime                @default(now()) @map("created_at")
  subcontractors   ProfileSubcontractor[]
  mappingRules     ProfileMappingRule[]
  subassetConfigs  ProfileSubassetConfig[]
  sessions         InventorySession[]

  @@map("mapping_profiles")
}

model ProfileSubcontractor {
  id               String                           @id @default(cuid())
  profileId        String                           @map("profile_id")
  name             String
  exportLabel      String                           @map("export_label")
  active           Boolean                          @default(true)
  profile          MappingProfile                   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  objectTypes      ProfileSubcontractorObjectType[]

  @@unique([profileId, name])
  @@map("profile_subcontractors")
}

model ProfileSubcontractorObjectType {
  subcontractorId String              @map("subcontractor_id")
  objectTypeId    String              @map("object_type_id")
  subcontractor   ProfileSubcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  objectType      ObjectType          @relation(fields: [objectTypeId], references: [id], onDelete: Cascade)

  @@id([subcontractorId, objectTypeId])
  @@map("profile_subcontractor_object_types")
}

model ProfileMappingRule {
  id                    String         @id @default(cuid())
  profileId             String         @map("profile_id")
  objectTypeId          String         @map("object_type_id")
  regime                String?
  region                String?
  minQuantity           Int?           @map("min_quantity")
  maxQuantity           Int?           @map("max_quantity")
  odooProductCode       String         @map("odoo_product_code")
  startPriceProductCode String?        @map("start_price_product_code")
  labelNl               String?        @map("label_nl")
  priority              Int            @default(0)
  active                Boolean        @default(true)
  profile               MappingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  objectType            ObjectType     @relation(fields: [objectTypeId], references: [id], onDelete: Cascade)

  @@map("profile_mapping_rules")
}

model ProfileSubassetConfig {
  id               String         @id @default(cuid())
  profileId        String         @map("profile_id")
  parentObjectTypeId String       @map("parent_object_type_id")
  childObjectTypeId  String       @map("child_object_type_id")
  sortOrder        Int            @default(0) @map("sort_order")
  profile          MappingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  parentObjectType ObjectType     @relation("SubassetParent", fields: [parentObjectTypeId], references: [id], onDelete: Cascade)
  childObjectType  ObjectType     @relation("SubassetChild", fields: [childObjectTypeId], references: [id], onDelete: Cascade)

  @@unique([profileId, parentObjectTypeId, childObjectTypeId])
  @@map("profile_subasset_configs")
}

model ScanJob {
  id           String     @id @default(cuid())
  scanRecordId String     @unique @map("scan_record_id")
  status       String     @default("pending")
  attempts     Int        @default(0)
  lastError    String?    @map("last_error")
  createdAt    DateTime   @default(now()) @map("created_at")
  processedAt  DateTime?  @map("processed_at")
  scanRecord   ScanRecord @relation(fields: [scanRecordId], references: [id])

  @@map("scan_jobs")
}
